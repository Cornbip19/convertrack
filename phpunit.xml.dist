<?xml version="1.0"?>
<phpunit
  bootstrap="tests/bootstrap.php"
  colors="true"
  beStrictAboutOutputDuringTests="true"
  failOnRisky="true"
  failOnWarning="true"
>
  <testsuites>
    <testsuite name="Convertrack WordPress integration">
      <directory suffix="Test.php">tests/integration</directory>
    </testsuite>
  </testsuites>
</phpunit>
